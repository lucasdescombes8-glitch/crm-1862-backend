# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL Connection (local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_1862_dev"

# PostgreSQL Connection (production - use environment-specific)
# DATABASE_URL="postgresql://user:password@db.example.com:5432/crm_1862_prod"

# ============================================================================
# SERVER
# ============================================================================

# Server port
PORT=5000

# Environment
NODE_ENV="development"

# Log level: error, warn, info, http, debug
LOG_LEVEL="debug"

# ============================================================================
# CORS
# ============================================================================

# Allowed origin for CORS
CORS_ORIGIN="http://localhost:3741"

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# JWT secret key (use strong random string in production)
JWT_SECRET="your-secret-key-change-in-production"

# JWT token expiry (e.g., "24h", "7d")
JWT_EXPIRY="24h"

# ============================================================================
# EMAIL (for notifications)
# ============================================================================

# SMTP configuration (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@groupe1862.com"

# ============================================================================
# AWS S3 (for file uploads, backups)
# ============================================================================

# AWS S3 credentials (optional, for file uploads)
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="crm-1862-files"
AWS_S3_REGION="eu-west-1"

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Sentry DSN (error tracking)
SENTRY_DSN="https://xxx@sentry.io/xxx"

# Analytics
GOOGLE_ANALYTICS_ID="UA-XXXXX-X"

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit: requests per window
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # 100 requests per 15 min
